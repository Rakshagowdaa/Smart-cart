{
  "info": {
    "name": "Smart Cart Microservices Collection (Updated)",
    "description": "API collection for Smart Cart E-commerce platform. All requests hit the API Gateway on port 8080.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"USER\"\n}"
            },
            "url": {"raw": "http://localhost:8080/api/auth/register", "host": ["localhost"], "port": "8080", "path": ["api", "auth", "register"]}
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {"raw": "http://localhost:8080/api/auth/login", "host": ["localhost"], "port": "8080", "path": ["api", "auth", "login"]}
          }
        }
      ]
    },
    {
      "name": "User Service",
      "item": [
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {"raw": "http://localhost:8080/api/users/1", "host": ["localhost"], "port": "8080", "path": ["api", "users", "1"]}
          }
        },
        {
          "name": "Block User (Admin)",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {"raw": "http://localhost:8080/api/users/1/block", "host": ["localhost"], "port": "8080", "path": ["api", "users", "1", "block"]}
          }
        },
        {
          "name": "Unblock User (Admin)",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {"raw": "http://localhost:8080/api/users/1/unblock", "host": ["localhost"], "port": "8080", "path": ["api", "users", "1", "unblock"]}
          }
        }
      ]
    },
    {
      "name": "Order Service",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "http://localhost:8080/api/orders/1?couponCode=WELCOME10&address=123 Smart St",
              "host": ["localhost"], "port": "8080", "path": ["api", "orders", "1"],
              "query": [{"key": "couponCode", "value": "WELCOME10"}, {"key": "address", "value": "123 Smart St"}]
            }
          }
        },
        {
          "name": "Get All Orders (Admin)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {"raw": "http://localhost:8080/api/orders/all", "host": ["localhost"], "port": "8080", "path": ["api", "orders", "all"]}
          }
        },
        {
          "name": "Get Revenue (Admin)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {"raw": "http://localhost:8080/api/orders/revenue", "host": ["localhost"], "port": "8080", "path": ["api", "orders", "revenue"]}
          }
        },
        {
          "name": "Get Sales Summary (Admin)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {"raw": "http://localhost:8080/api/orders/summary", "host": ["localhost"], "port": "8080", "path": ["api", "orders", "summary"]}
          }
        }
      ]
    },
    {
      "name": "Notification Service",
      "item": [
        {
          "name": "Get User Notifications",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {"raw": "http://localhost:8080/api/notifications/user/1", "host": ["localhost"], "port": "8080", "path": ["api", "notifications", "user", "1"]}
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "jwt_token",
      "value": "YOUR_JWT_TOKEN_HERE"
    }
  ]
}
