    {
      "name": "Payment Service",
      "item": [
        {
          "name": "Create Razorpay Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/payments/order?userId=1&orderId=1&amount=9.98",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "payments", "order"],
              "query": [
                {
                  "key": "userId",
                  "value": "1"
                },
                {
                  "key": "orderId",
                  "value": "1"
                },
                {
                  "key": "amount",
                  "value": "9.98"
                }
              ]
            }
          }
        },
        {
          "name": "Verify Payment Signature",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"razorpay_order_id\": \"order_mock123\",\n  \"razorpay_payment_id\": \"pay_mock123\",\n  \"razorpay_signature\": \"sig_mock123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/payments/verify",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "payments", "verify"]
            }
          }
        }
